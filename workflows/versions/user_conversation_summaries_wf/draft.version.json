        "config": {
          "code": "const raw = context.steps && context.steps.Tool0001 ? context.steps.Tool0001.output : null;\nlet tableResult = raw;\n\nif (typeof raw === \"string\") {\n  try {\n    tableResult = JSON.parse(raw);\n  } catch (error) {\n    tableResult = null;\n  }\n}\n\nconst data = tableResult && typeof tableResult === \"object\" && tableResult.data && typeof tableResult.data === \"object\"\n  ? tableResult.data\n  : {};\nconst rows = Array.isArray(data.rows) ? data.rows : [];\nconst row = rows.length > 0 && rows[0] && typeof rows[0] === \"object\" ? rows[0] : null;\nconst values = row && row.values && typeof row.values === \"object\" ? row.values : {};\nconst metadata = values.rolling_memory_metadata && typeof values.rolling_memory_metadata === \"object\"\n  ? values.rolling_memory_metadata\n  : {};\nconst sessionDetails = values.session_details && typeof values.session_details === \"object\"\n  ? values.session_details\n  : {};\nconst summaryText = typeof values.current_conversation_summary === \"string\"\n  ? values.current_conversation_summary\n  : \"\";\nconst updatedAt = values.updated_at || (row && (row.updatedAt || row.updated_at)) || null;\nconst sessionEnd = sessionDetails.session_ended_at || sessionDetails.sessionEndedAt || updatedAt || null;\n\ncontext.tableResult = tableResult || {};\ncontext.latestSummary = {\n  id: (row && (row.id || row._id)) || values.id || null,\n  userId: values.user_id || null,\n  projectId: values.project_id || null,\n  tenantId: values.tenant_id || null,\n  currentConversationSummary: summaryText,\n  rollingMemoryMetadata: metadata,\n  sessionDetails: sessionDetails,\n  createdAt: values.created_at || (row && (row.createdAt || row.created_at)) || null,\n  updatedAt: updatedAt\n};\ncontext.summary_text = summaryText;\ncontext.summary_json = metadata;\ncontext.session_details = sessionDetails;\ncontext.session_end = sessionEnd || '';",
